<gpx version="1.1" creator="generate_valladolid.py -- OSM routing.openstreetmap.de" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata>
    <name>Belchite to Valladolid - Enhanced Route</name>
    <desc>The 9 waypoints plus in-between detours (Fuendetodos, Anento, Laguna de Gallocanta, Medinaceli, Berlanga de Duero, Ermita de San Baudelio, Rello, Calatanazor, Castillo de Ucero, Desfiladero de la Yecla, Caleruega), in the order the driver encounters them.</desc>
  </metadata>
  <wpt lat="41.304741" lon="-0.754469">
    <name>1. Belchite</name>
    <desc>Haunted Civil War ghost town. Guided tours only, book ahead.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.343343" lon="-0.959369">
    <name>1a. Fuendetodos</name>
    <desc>Goya's birthplace and engraving museum. South off the A-222.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.114405" lon="-1.414434">
    <name>2. Daroca</name>
    <desc>Walled town, 600 m water tunnel, bleeding-host miracle relics.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.069821" lon="-1.333968">
    <name>2a. Anento</name>
    <desc>One of Spain's prettiest villages; the Aguallueve grotto.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="40.974119" lon="-1.506341">
    <name>2b. Laguna de Gallocanta</name>
    <desc>Up to 60,000 migrating cranes in winter; W. Europe's largest salt lake.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.353168" lon="-1.646845">
    <name>3. Calatayud</name>
    <desc>Mudéjar towers, Roman Bilbilis, leaning tower, La Dolores inn.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.154611" lon="-2.440639">
    <name>3a. Medinaceli</name>
    <desc>Spain's only three-span Roman triumphal arch; hilltop village.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.138109" lon="-2.263039">
    <name>4. Arcos de Jalón</name>
    <desc>Frontier town, ruined hilltop castle; Sta. María de Huerta nearby.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.512880" lon="-2.559421">
    <name>5. Almazán</name>
    <desc>Perfect Castilian plaza on a cliff over the Duero; Romanesque San Miguel.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.464152" lon="-2.862346">
    <name>5a. Berlanga de Duero</name>
    <desc>15th-c. castle; church with the Galápagos friar's stuffed crocodile.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.418273" lon="-2.790160">
    <name>5b. Ermita de San Baudelio</name>
    <desc>11th-c. Mozarabic frescoes and the famous palm-tree pillar.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.373900" lon="-2.726900">
    <name>5c. Rello</name>
    <desc>Near-perfect tiny walled medieval village.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.699159" lon="-2.817518">
    <name>5d. Calatañazor</name>
    <desc>Frozen-in-time village; 'Almanzor lost his drum here' (1002); juniper forest.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.587565" lon="-3.066855">
    <name>6. El Burgo de Osma</name>
    <desc>Gothic cathedral, arcaded streets; Gormaz and Tiermes nearby.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.719060" lon="-3.045576">
    <name>6a. Castillo de Ucero</name>
    <desc>Gothic-Templar castle; gateway to the Río Lobos canyon.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.828642" lon="-3.087678">
    <name>7. San Leonardo de Yagüe</name>
    <desc>Pine forests; Templar Ermita de San Bartolomé in Río Lobos.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.949893" lon="-3.442313">
    <name>7a. Desfiladero de la Yecla</name>
    <desc>Narrow gorge with hanging walkways; 100+ vulture pairs.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.962462" lon="-3.418922">
    <name>8. Santo Domingo de Silos</name>
    <desc>Romanesque cloister, chart-topping chanting monks, poet's cypress.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.825348" lon="-3.485818">
    <name>8a. Caleruega</name>
    <desc>Birthplace of St. Dominic; oldest cellar in the D.O.</desc>
    <type>detour</type>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="41.598472" lon="-4.124511">
    <name>9. Peñafiel</name>
    <desc>Ship-shaped castle and wine museum; medieval Plaza del Coso.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.654364" lon="-4.722273">
    <name>10. Valladolid</name>
    <desc>Journey's end.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>

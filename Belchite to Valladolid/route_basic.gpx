  <metadata>
    <name>Belchite to Valladolid - Basic Route</name>
    <desc>The 9 original waypoints: Belchite, Daroca, Calatayud, Arcos de Jalon, Almazan, El Burgo de Osma, San Leonardo de Yague, Santo Domingo de Silos, Penafiel, ending in Valladolid.</desc>
  </metadata>
  <wpt lat="41.304741" lon="-0.754469">
    <name>1. Belchite</name>
    <desc>Haunted Civil War ghost town. Guided tours only, book ahead.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.114405" lon="-1.414434">
    <name>2. Daroca</name>
    <desc>Walled town, 600 m water tunnel, bleeding-host miracle relics.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.353168" lon="-1.646845">
    <name>3. Calatayud</name>
    <desc>Mudéjar towers, Roman Bilbilis, leaning tower, La Dolores inn.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.138109" lon="-2.263039">
    <name>4. Arcos de Jalón</name>
    <desc>Frontier town, ruined hilltop castle; Sta. María de Huerta nearby.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.512880" lon="-2.559421">
    <name>5. Almazán</name>
    <desc>Perfect Castilian plaza on a cliff over the Duero; Romanesque San Miguel.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.587565" lon="-3.066855">
    <name>6. El Burgo de Osma</name>
    <desc>Gothic cathedral, arcaded streets; Gormaz and Tiermes nearby.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.828642" lon="-3.087678">
    <name>7. San Leonardo de Yagüe</name>
    <desc>Pine forests; Templar Ermita de San Bartolomé in Río Lobos.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.962462" lon="-3.418922">
    <name>8. Santo Domingo de Silos</name>
    <desc>Romanesque cloister, chart-topping chanting monks, poet's cypress.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.598472" lon="-4.124511">
    <name>9. Peñafiel</name>
    <desc>Ship-shaped castle and wine museum; medieval Plaza del Coso.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="41.654364" lon="-4.722273">
    <name>10. Valladolid</name>
    <desc>Journey's end.</desc>
    <type>waypoint</type>
    <sym>Flag, Blue</sym>
  </wpt>
